{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2017",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "paths": {
      "@graphql-tools/apollo-engine-loader": ["src/types/graphql-tools-apollo-engine-loader"]
    },
    "incremental": true,
    "strict": true,
    "skipLibCheck": false
  }
}
